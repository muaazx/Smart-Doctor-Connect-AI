{
  "entities": {
    "Doctor": {
      "title": "Doctor Profile",
      "description": "Information about a registered doctor.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "location": { "type": "string" },
        "consultationType": { "type": "string", "enum": ["Online", "Physical", "Both"] },
        "experience": { "type": "string" },
        "rating": { "type": "number" },
        "available": { "type": "boolean" },
        "profilePicUrl": { "type": "string" },
        "bio": { "type": "string" },
        "availableSlots": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "specialization", "location"]
    },
    "Patient": {
      "title": "Patient Profile",
      "description": "Information about a registered patient.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Doctor-Patient appointment details.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorName": { "type": "string" },
        "patientName": { "type": "string" },
        "specialization": { "type": "string" },
        "timeSlot": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["Online", "Physical"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["doctorId", "patientId", "timeSlot", "date", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat session between doctor and patient, potentially AI-assisted.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorName": { "type": "string" },
        "patientName": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "isAI": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["doctorId", "patientId"]
    }
  },
  "firestore": {
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Collection of doctor profiles."
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Collection of patient profiles."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of appointments."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of chats between patients and doctors."
    }
  }
}
